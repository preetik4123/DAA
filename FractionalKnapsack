#include <iostream>
#include <iomanip>
using namespace std;

int main(){

    int n ;

    cout<<"Enter the number of items which you want to enter:\n";
    cin>>n;

    float weight[100] , profit[100] , ratio[100];

    cout<<"Enter the weight and profit of each item:\n";

    for(int i = 0 ; i < n ; i++){

        cout<<"For Item "<<i+1<<" \n";

        cout<<"Item "<<i+1 <<" : Weight"<<endl;
        cin>>weight[i];

        cout<<"Item "<<i+1<<" : Profit"<<endl;
        cin>>profit[i];

        ratio[i] = profit[i]/weight[i];
    }

    float W;

    cout<<"Enter the capacity of the knapsack ";
    cin>>W;

    // Sorting
    for(int i = 0 ; i < n-1 ; i++){

        for(int j = i+1 ; j < n ; j++){

            if(ratio[i] < ratio[j]){

                float temp;

                // Swap ratio
                temp = ratio[i];
                ratio[i] = ratio[j];
                ratio[j] = temp;

                // Swap weight
                temp = weight[i];
                weight[i] = weight[j];
                weight[j] = temp;

                // Swap profit
                temp = profit[i];
                profit[i] = profit[j];
                profit[j] = temp;
            }
        }
    }

    cout<<"Items after sorting the items by Profit per kg:\n";

    cout<<"---------------------------------------------------\n";

    cout<<"Weight\tProfit\tProfit/KG\n";

    for(int i = 0 ; i < n ; i++) {

        cout<<weight[i]<<" \t"
            <<profit[i]<<" \t"
            <<fixed<<setprecision(2)
            <<ratio[i]<<endl;
    }

    float totalProfit = 0 ;

    cout<<"----------------------------------------\n";

    cout<<"Step by Step Selection\n";

    for(int i = 0 ; i < n ; i++){

        if(weight[i] <= W){

            cout<<"Take full item "<<i+1
                <<" (Weight "<<weight[i]
                <<" & Profit "<<profit[i]
                <<")"<<endl;

            totalProfit = totalProfit + profit[i];

            W = W - weight[i];
        }

        else{

            cout<<"Remaining Capacity " << W << " kg\n";

            cout<<"Current item gives "
                <<ratio[i]
                <<" profit per kg\n";

            float addedProfit = ratio[i] * W;

            cout<<"Take only Weight "
                <<W
                <<" for the item "
                <<i+1
                <<endl;

            cout<<"Added Profit "
                << W
                << " * "
                << ratio[i]
                << " = "
                << addedProfit
                <<endl;

            totalProfit = totalProfit + addedProfit;

            W = 0;

            break;
        }
    }

    cout<<"---------------------------------------\n";

    cout<<"Maximum profit = "
        <<fixed<<setprecision(2)
        <<totalProfit<<endl;

    return 0;
}

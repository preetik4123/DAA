#include <iostream>
using namespace std;

int main()
{
    int n;

    cout << "Enter number of elements: ";
    cin >> n;

    int arr[100];

    cout << "Enter array elements:\n";

    for(int i = 0; i < n; i++)
        cin >> arr[i];

    int key;

    cout << "Enter element to search: ";
    cin >> key;

    int found = 0;

    // Linear Search
    for(int i = 0; i < n; i++)
    {
        cout << "\nChecking arr[" << i
             << "] = " << arr[i]
             << endl;

        if(arr[i] == key)
        {
            cout << "\nElement Found at Index "
                 << i << endl;

            found = 1;

            break;
        }
    }

    if(found == 0)
    {
        cout << "\nElement Not Found";
    }

    return 0;
}

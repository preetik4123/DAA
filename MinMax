#include <iostream>
using namespace std;

int main() {

    int n;

    cout << "Enter the number of elements" << endl;
    cin >> n;

    int arr[100];

    cout << "Enter the elements in the array" << endl;

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int min, max;

    int i;

    // Even number of elements
    if(n % 2 == 0) {

        cout << "Number of elements in the array is EVEN" << endl;

        if(arr[0] < arr[1]) {

            min = arr[0];
            max = arr[1];
        }
        else {

            min = arr[1];
            max = arr[0];
        }

        cout << "Initial Minimum = " << min << endl;
        cout << "Initial Maximum = " << max << endl;

        i = 2;
    }

    // Odd number of elements
    else {

        cout << "Number of elements in the array is ODD" << endl;

        min = max = arr[0];

        cout << "Initial Minimum and Maximum = "
             << arr[0] << endl;

        i = 1;
    }

    // Process pairs
    while(i < n - 1) {

        cout << "\nComparing "
             << arr[i]
             << " and "
             << arr[i+1]
             << endl;

        // First compare pair internally
        if(arr[i] < arr[i+1]) {

            cout << arr[i]
                 << " is smaller" << endl;

            // Compare smaller with min
            if(arr[i] < min) {

                min = arr[i];

                cout << "New Min = "
                     << min << endl;
            }

            // Compare larger with max
            if(arr[i+1] > max) {

                max = arr[i+1];

                cout << "New Max = "
                     << max << endl;
            }
        }

        else {

            cout << arr[i+1]
                 << " is smaller" << endl;

            // Compare smaller with min
            if(arr[i+1] < min) {

                min = arr[i+1];

                cout << "New Min = "
                     << min << endl;
            }

            // Compare larger with max
            if(arr[i] > max) {

                max = arr[i];

                cout << "New Max = "
                     << max << endl;
            }
        }

        i = i + 2;
    }

    cout << "\nFinal Maximum = "
         << max << endl;

    cout << "Final Minimum = "
         << min << endl;

    return 0;
}

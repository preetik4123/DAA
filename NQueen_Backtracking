#include <iostream>
using namespace std;
#define MAX 10

void printBoard(int board[MAX][MAX] , int n){
    for(int i = 0 ; i < n ; i++){
        for(int j = 0 ; j < n ; j++){
            cout<<board[i][j]<<" ";
        }
        cout<<endl;
    }
}
bool isSafe(int board[MAX][MAX] , int row , int col , int n){
    int i , j ;
    
    for(int i = 0 ; i < col ; i++){
        if(board[row][i] == 1){
            return false;
        }
    }
    
    for(int i = row , j = col ; i >=0 && j >= 0 ; i--,j--){
        if(board[i][j] == 1){
            return false;
        }
    }
    
    for(int i = row , j = col ; i < n && j >= 0 ; i++ , j--){
        if(board[i][j] == 1){
            return false;
        }
    }
    return true;
}

bool solveNQueen(int board[MAX][MAX] , int col, int n){
    if(col >= n){
        return true;
    }
    for(int i = 0 ; i < n ; i++){
        cout<<"Checking Position (" << i  << "," << col << ")"<<endl;
        if(isSafe(board,i,col,n)){
            cout<<"Queen Safely Place"<<endl;
            board[i][col] = 1;
            printBoard(board,n);
            
            if(solveNQueen(board,col+1,n)){
                return true;
            }
            cout<<"Backtracking at Position ("<< i << ","<<col<< ")"<<endl;
            board[i][col] = 0;
            printBoard(board,n);
        }
        else{
            cout<<"-> Not Safe"<<endl;
        }
    }
    return false;
}
int main(){
    int n;
    cout<<"Enter the number of Quuens to be entered"<<endl;
    cin>>n;
    int board[MAX][MAX] = {0};
    if(solveNQueen(board,0,n)){
        cout<<"\n\n Final Solution"<<endl;
        printBoard(board,n);
    }
    else{
        cout<<"Solution does not exist"<<endl;
    }
    return 0;
}
